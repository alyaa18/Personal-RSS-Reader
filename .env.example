# ── Connection ────────────────────────────────────────────────
ConnectionStrings__DefaultConnection=Data Source=Data/app.db
Storage__DataDirectory=Data

# ── JWT ───────────────────────────────────────────────────────
Jwt__Secret=CHANGE_ME_TO_A_LONG_RANDOM_STRING_AT_LEAST_32_CHARS
Jwt__Issuer=PersonalRSSReader
Jwt__Audience=PersonalRSSReader

# ── App ───────────────────────────────────────────────────────
# Used for verification email links & CORS
App__BaseUrl=http://localhost:5001

# ── Email (SMTP) ──────────────────────────────────────────────
# Leave Host empty to auto-verify emails in dev mode
Email__Host=
Email__Port=587
Email__Username=
Email__Password=
Email__FromAddress=noreply@personalrssreader.app
Email__FromName=Personal RSS Reader
Email__EnableSsl=true
Email__AutoVerify=true

# ── Retention / Cleanup ───────────────────────────────────────
Retention__MaxArticleAgeDays=60
Retention__CleanupIntervalHours=24

# ── Frontend ──────────────────────────────────────────────────
# The API base URL the frontend calls
VITE_API_BASE_URL=http://localhost:5001/api
