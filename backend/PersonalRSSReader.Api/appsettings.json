{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Storage": {
    "DataDirectory": "Data"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=Data/app.db"
  },
