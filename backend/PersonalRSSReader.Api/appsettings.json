    "Username": "",
    "Password": "",
    "FromAddress": "noreply@personalrssreader.app",
    "FromName": "Personal RSS Reader",
    "EnableSsl": true,
    "AutoVerify": true
  },
  "App": {
    "BaseUrl": "http://localhost:5001"
  }
}